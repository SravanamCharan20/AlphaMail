# Server
NODE_ENV=development
PORT=9000
CLIENT_ORIGIN=http://localhost:3000

# Database
MONGO_URL=mongodb://127.0.0.1:27017/alphamail

# Redis
# Prefer REDIS_URL in containers, for example: redis://redis:6379
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# Auth
JWT_SECRET=replace-with-a-strong-secret

# Google OAuth / Gmail
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:9000/googleAuth/google/callback

# Pub/Sub
PUBSUB_TOPIC=
PUBSUB_PUSH_SERVICE_ACCOUNT=
PUBSUB_PUSH_AUDIENCE=
PUBSUB_LABELS=INBOX
